---
import BaseLayout from "../components/BaseLayout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import PostList from "../components/PostList.astro";
import Search from "../components/Search.astro";
import { getPublishedPosts } from "../lib/posts";
import { siteConfig, withBase } from "../lib/site";

const posts = await getPublishedPosts();
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  url: Astro.site,
  description: siteConfig.description,
  author: {
    "@type": "Person",
    name: siteConfig.author
  }
};
---

<BaseLayout
  title={`${siteConfig.title} | Home`}
  description={siteConfig.description}
  canonicalPath={withBase("/")}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="hero-meta">
          <span>Dark mode only</span>
          <span>Markdown first</span>
          <span>Simple by design</span>
        </p>
        <h1>{siteConfig.homeTitle}</h1>
        <p>{siteConfig.homeIntro}</p>
      </div>
      <aside class="hero-panel">
        <p class="section-kicker">Right now</p>
        <h2>Recent posts by date.</h2>
        <p>
          The homepage stays intentionally simple: one flowing list, quick scanning,
          and room to add featured posts later without changing the writing workflow.
        </p>
      </aside>
    </div>
  </section>

  <div class="home-sections">
    <section class="page-panel" aria-labelledby="recent-posts-heading">
      <div class="section-heading">
        <p class="section-kicker">Blog</p>
        <h2 id="recent-posts-heading">Recent posts</h2>
      </div>
      <PostList posts={posts} />
    </section>

    <Search />
    <NewsletterSignup />
  </div>
</BaseLayout>
