---
import BaseLayout from "../components/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { getPublishedPosts } from "../lib/posts";
import { siteConfig, withBase } from "../lib/site";

const posts = await getPublishedPosts();
const featuredPosts = posts.filter((post) => post.data.featured);
const recentPosts = posts.filter((post) => !post.data.featured);
const progressRatio = Math.min(siteConfig.currentProgress / siteConfig.goalAmount, 1);
const progressPercent = Math.round(progressRatio * 100);
const currencyFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 0
});
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteConfig.title,
  url: Astro.site,
  description: siteConfig.description,
  author: {
    "@type": "Person",
    name: siteConfig.author
  }
};
---

<BaseLayout
  title={`${siteConfig.title} | Home`}
  description={siteConfig.description}
  canonicalPath={withBase("/")}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="hero-meta">
          <span>Transparency</span>
          <span>Lessons Learned</span>
          <span>Strategy</span>
        </p>
        <h1>{siteConfig.homeTitle}</h1>
        <p>{siteConfig.homeIntro}</p>
      </div>
      <aside class="progress-card" aria-label="Progress toward 500 thousand dollars">
        <p class="progress-kicker">Current progress</p>
        <div class="progress-thermometer" aria-hidden="true">
          <span class="progress-cap">{currencyFormatter.format(siteConfig.goalAmount)}</span>
          <div class="progress-track">
            <div class="progress-fill" style={`height: ${Math.max(progressRatio * 100, 3)}%;`}></div>
          </div>
          <span class="progress-bulb"></span>
        </div>
        <p class="progress-amount">{currencyFormatter.format(siteConfig.currentProgress)}</p>
        <p class="progress-note">{progressPercent}% of the way to the goal</p>
      </aside>
    </div>
  </section>

  <div class="home-sections">
    <section class="page-panel" aria-labelledby="featured-posts-heading">
      <div class="section-heading">
        <p class="section-kicker">Featured</p>
        <h2 id="featured-posts-heading">Featured posts</h2>
      </div>
      {featuredPosts.length ? (
        <PostList posts={featuredPosts} />
      ) : (
        <p class="subtle-note">Mark a post as featured to highlight it here.</p>
      )}
    </section>

    <section class="page-panel" aria-labelledby="recent-posts-heading">
      <div class="section-heading">
        <p class="section-kicker">Blog</p>
        <h2 id="recent-posts-heading">Recent posts</h2>
      </div>
      <PostList posts={recentPosts} />
    </section>
  </div>
</BaseLayout>
