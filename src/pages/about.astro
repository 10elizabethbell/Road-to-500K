---
import BaseLayout from "../components/BaseLayout.astro";
import { siteConfig, withBase } from "../lib/site";
---

<BaseLayout
  title={`About | ${siteConfig.title}`}
  description={siteConfig.aboutIntro}
  canonicalPath={withBase("/about/")}
>
  <section class="page-panel">
    <div class="about-grid">
      <div>
        <p class="section-kicker">About</p>
        <h1>Ellie Bell</h1>
        <p>{siteConfig.aboutIntro}</p>
        <p>{siteConfig.aboutBody}</p>
        <p>
          This blog is for following my journey through profiting $500,000 in the next 8 years, not including income from my full time job. I will share what I try, what works, what doesn't work, why, and the lessons I learn.
        </p>
      </div>
      <img src={withBase("/personal-photo.png")} alt="Portrait of Ellie Bell" />
    </div>
  </section>
</BaseLayout>
